{
  "service": "ai-restaurant-recommendation",
  "version": "phase0-v1",
  "request_schema": {
    "type": "object",
    "required": [
      "price",
      "place",
      "rating",
      "cuisine"
    ],
    "properties": {
      "price": {
        "type": "number",
        "description": "Maximum budget (e.g., 1500)"
      },
      "place": {
        "type": "string",
        "minLength": 1
      },
      "rating": {
        "type": "number",
        "minimum": 0,
        "maximum": 5
      },
      "cuisine": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": [
      "recommendations",
      "summary"
    ],
    "properties": {
      "recommendations": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "name",
            "place",
            "price_for_two",
            "rating",
            "cuisines",
            "reason"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "place": {
              "type": "string",
              "minLength": 1
            },
            "price_for_two": {
              "type": "integer",
              "minimum": 0
            },
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 5
            },
            "cuisines": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "summary": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
